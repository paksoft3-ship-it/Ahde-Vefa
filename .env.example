# AHDE VEFA — Environment variables (example)
# Copy this file to .env.local and fill in real values when integrations are ready.
# NEVER commit real secrets to the repository.

# Public site URL (used for metadata / canonical links)
NEXT_PUBLIC_SITE_URL=

# Payment provider (e.g. iyzico, PayTR, Stripe)
PAYMENT_PROVIDER_API_KEY=

# Transactional email provider (e.g. Resend, SendGrid, SES)
EMAIL_PROVIDER_API_KEY=

# SMS provider (e.g. Netgsm, Twilio)
SMS_PROVIDER_API_KEY=

# WhatsApp Business / Cloud API
WHATSAPP_PROVIDER_TOKEN=

# Database connection string
DATABASE_URL=

# Object storage bucket (receipts, media)
STORAGE_BUCKET=
